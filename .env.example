# Mistral Conductor v3.3 — Environment Variables
# Rename this file to .env before running proxy.js

# Gemini — supports multiple keys (comma-separated), rotated round-robin
# Get keys: https://aistudio.google.com/app/apikey
# Tip: 3 keys = 45 RPM free tier
GEMINI_API_KEYS=AIza...,AIza...,AIza...

# Groq — supports multiple keys (comma-separated)
# Get key: https://console.groq.com/keys
GROQ_API_KEYS=gsk_...

# Mistral — also used as the smart router if present
# Get key: https://console.mistral.ai/
MISTRAL_API_KEYS=msk_...

# OpenAI
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEYS=sk-...

# Anthropic (Claude)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEYS=sk-ant-...

# Kimi (Moonshot AI) — OpenAI-compatible, model: kimi-k2.5
# Get key: https://platform.moonshot.ai/
KIMI_API_KEYS=sk-...

# Manus — async task agent API (NOT a chat completions endpoint)
# Tasks take 3–60s. taskMode: chat|adaptive|agent, agentProfile: speed|quality
# Get key: https://manus.im/ → Settings → Build with Manus API
MANUS_API_KEYS=manus_...

# Optional: server port (default 3000)
PORT=3000
